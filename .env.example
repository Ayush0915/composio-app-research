# ============================================================
# Composio App Research Pipeline — Environment Variables
# ============================================================
# Copy this file to .env and fill in your keys before running.
# All three keys are required. Free-tier links are below.

# Composio API Key
# Sign up free at: https://app.composio.dev/
COMPOSIO_API_KEY=your_composio_api_key_here

# Groq API Key (LLM provider — Llama 3)
# Get free key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Tavily Search API Key (free 1,000 searches/month)
# Sign up at: https://app.tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# Optional: override concurrency (default: 6)
# RESEARCH_CONCURRENCY=6
